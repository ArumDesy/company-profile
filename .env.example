# Supabase — ambil dari Project Settings > API (dialog "Connect")
NEXT_PUBLIC_SUPABASE_URL=https://GANTI_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=GANTI_ANON_ATAU_PUBLISHABLE_KEY

# Hanya untuk server (jangan diawali NEXT_PUBLIC_). untuk operasi admin.
SUPABASE_SECRET_KEY=GANTI_SECRET_KEY

# Daftar email yang boleh masuk dashboard (pisahkan koma). Server-only.
# Email di luar daftar ditolak walau auth Supabase berhasil (termasuk login Google).
ADMIN_EMAILS=email-admin@contoh.com

# Koneksi ke Postgres via shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://GANTI_USER:GANTI_PASSWORD@GANTI_HOST:6543/GANTI_DATABASE?pgbouncer=true"

# Koneksi ke Postgres via shared session-mode pooler (digunakan untuk migrasi database)
DIRECT_URL="postgresql://GANTI_USER:GANTI_PASSWORD@GANTI_HOST:5432/GANTI_DATABASE"